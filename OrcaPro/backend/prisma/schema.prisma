generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Nossas Tabelas do Banco de Dados ---

model User {
  id        Int      @id @default(autoincrement())
  name      String
  usuario   String   @unique
  password  String   
  createdAt DateTime @default(now())
}

model Cliente {
  id          Int      @id @default(autoincrement())
  nome        String
  cpfCnpj     String?
  email       String?
  telefone    String
  cidade      String?
  bairro      String?
  rua         String?
  numero      String?
  cep         String?
  observacoes String?
  createdAt   DateTime @default(now())
  orcamentos  Orcamento[]
}

model Material {
  id          Int      @id @default(autoincrement())
  nome        String
  categoria   String?
  valor       Float
  unidade     String?
  createdAt   DateTime @default(now())
}

model Orcamento {
  id              Int      @id @default(autoincrement())
  titulo          String
  clienteId       Int
  cliente         Cliente  @relation(fields: [clienteId], references: [id])
  
  tipoMaoDeObra   String   
  maoDeObraValor  Float
  maoDeObraQtde   Float?   @default(1)
  tipoLucro       String   
  lucroValor      Float
  lucroQtde       Float?   @default(1)
  totalFinal      Float
  status          String   @default("analise") 
  
  tipoMovel       String?
  ambiente        String?
  medidas         String?
  prazo           String?
  pagamento       String?
  validade        String?
  observacoes     String?
  
  materiais       OrcamentoMaterial[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OrcamentoMaterial {
  id          Int       @id @default(autoincrement())
  orcamentoId Int
  orcamento   Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  nome        String    
  valor       Float     
  quantidade  Float
}