generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Nossas Tabelas do Banco de Dados ---

model User {
  id        Int      @id @default(autoincrement())
  name            String
  usuario         String   @unique
  email           String?  @unique
  avatar          String?
  password        String
  isAdmin         Boolean  @default(false)
  nomeMarcenaria  String?
  logoMarcenaria  String?
  createdAt       DateTime @default(now())

  // Relacionamentos: O que pertence a este usuário
  clientes           Cliente[]
  materiais          Material[]
  orcamentos         Orcamento[]
  auditLogs          AuditLog[]
  opcoesCustomizadas OpcaoCustomizada[]
  configMarcenaria   ConfiguracaoMarcenaria?
}

model Cliente {
  id          Int      @id @default(autoincrement())
  nome        String
  cpfCnpj     String?
  email       String?
  telefone    String
  cidade      String?
  bairro      String?
  rua         String?
  numero      String?
  cep         String?
  observacoes    String?
  telegramChatId String?
  createdAt      DateTime @default(now())
  orcamentos     Orcamento[]

  // Etiqueta de dono (SaaS)
  userId      Int
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Material {
  id                 Int      @id @default(autoincrement())
  nome               String
  categoria          String?
  valor              Float
  unidade            String?
  quantidadeEstoque  Float?
  estoqueMinimo      Float?
  createdAt          DateTime @default(now())

  // Etiqueta de dono (SaaS)
  userId             Int
  user               User     @relation(fields: [userId], references: [id])
  orcamentoMateriais OrcamentoMaterial[]

  @@index([userId])
  @@unique([nome, userId])
}

model Orcamento {
  id              Int      @id @default(autoincrement())
  titulo          String
  clienteId       Int
  cliente         Cliente  @relation(fields: [clienteId], references: [id])
  
  tipoMaoDeObra   String   
  maoDeObraValor  Float
  maoDeObraQtde   Float?   @default(1)
  tipoLucro       String   
  lucroValor      Float
  lucroQtde       Float?   @default(1)
  totalFinal      Float
  status          String   @default("Aguardando")
  
  tipoMovel       String?
  ambiente        String?
  medidas         String?
  prazo           String?
  pagamento       String?
  validade        String?
  observacoes     String?
  
  materiais       OrcamentoMaterial[]
  pagamentos      Pagamento[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Contrato gerado automaticamente ao aprovar
  contratoToken    String?   @unique
  contratoGeradoEm DateTime?
  contratoAceito   Boolean   @default(false)
  contratoAceitoEm DateTime?

  // Ordem de produção gerada automaticamente ao aprovar
  ordemGeradaEm    DateTime?

  // Etiqueta de dono (SaaS)
  userId          Int
  user            User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@unique([titulo, clienteId, userId])
}

model OrcamentoMaterial {
  id          Int       @id @default(autoincrement())
  orcamentoId Int
  orcamento   Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  nome        String
  valor       Float
  quantidade  Float
  materialId  Int?
  material    Material? @relation(fields: [materialId], references: [id], onDelete: SetNull)
}

model OpcaoCustomizada {
  id        Int      @id @default(autoincrement())
  tipo      String   // "ambiente" | "pagamento" | "material_categoria" | "material_unidade"
  nome      String
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([tipo, nome, userId])
  @@index([userId])
}

model Pagamento {
  id            Int       @id @default(autoincrement())
  orcamentoId   Int
  orcamento     Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  descricao     String
  valor         Float
  dataPagamento DateTime  @default(now())
  createdAt     DateTime  @default(now())

  @@index([orcamentoId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  acao      String
  recurso   String
  recursoId Int?
  detalhe   String?
  criadoEm  DateTime @default(now())

  @@index([userId])
  @@index([criadoEm])
}

// --- Módulo de Engenharia Paramétrica ---

model ConfiguracaoMarcenaria {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique
  user               User     @relation(fields: [userId], references: [id])
  espEstrutura       Int      @default(18)
  espFundo           Int      @default(6)
  rasgoProfundidade  Int      @default(10)
  rasgoBorda         Int      @default(10)
  folgaPorta         Int      @default(4)
  avancoTamponamento Int      @default(25)
  larguraReforco     Int      @default(100)
  larguraTiraOculta  Int      @default(60)
  kerfSerra          Int      @default(3)
  margemPerda        Float    @default(0.10)
  recuoPrateleira    Int      @default(20)
  folgaPrateleiraLat Int      @default(2)
  folgaAlturaGaveta  Int      @default(4)
  corCaixaInterna    String   @default("Branco")
  chapaLargura       Int      @default(2750)
  chapaAltura        Int      @default(1850)
  configurado        Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tiposMovel TipoMovel[]
  chapas     Chapa[]
  fitas      Fita[]
  corredicas Corredica[]
  ferragens  Ferragem[]
}

model TipoMovel {
  id                   Int                    @id @default(autoincrement())
  configId             Int
  config               ConfiguracaoMarcenaria @relation(fields: [configId], references: [id], onDelete: Cascade)
  nome                 String
  tamponamentoTampo    Boolean                @default(false)
  tamponamentoLaterais Boolean                @default(false)
  tamponamentoBase     Boolean                @default(false)
  tipoPorta            String                 @default("SOBREPOSTA")

  @@index([configId])
}

model Chapa {
  id         Int                    @id @default(autoincrement())
  configId   Int
  config     ConfiguracaoMarcenaria @relation(fields: [configId], references: [id], onDelete: Cascade)
  cor        String
  espessura  Int
  precoChapa Float

  @@index([configId])
}

model Fita {
  id         Int                    @id @default(autoincrement())
  configId   Int
  config     ConfiguracaoMarcenaria @relation(fields: [configId], references: [id], onDelete: Cascade)
  cor        String
  largura    Int
  precoMetro Float

  @@index([configId])
}

model Corredica {
  id                Int                    @id @default(autoincrement())
  configId          Int
  config            ConfiguracaoMarcenaria @relation(fields: [configId], references: [id], onDelete: Cascade)
  tipo              String
  nome              String
  descontoLarguraMm Int
  comprimentos      String

  @@index([configId])
}

model Ferragem {
  id       Int                    @id @default(autoincrement())
  configId Int
  config   ConfiguracaoMarcenaria @relation(fields: [configId], references: [id], onDelete: Cascade)
  nome     String
  tipo     String // DOBRADICA|PUXADOR|PE|OUTRO
  unidade  String // "un" | "par"
  preco    Float

  @@index([configId])
}