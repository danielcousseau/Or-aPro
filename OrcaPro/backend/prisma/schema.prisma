generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Nossas Tabelas do Banco de Dados ---

model User {
  id        Int      @id @default(autoincrement())
  name            String
  usuario         String   @unique
  email           String?  @unique
  avatar          String?
  password        String
  isAdmin         Boolean  @default(false)
  nomeMarcenaria  String?
  logoMarcenaria  String?
  createdAt       DateTime @default(now())

  // Relacionamentos: O que pertence a este usuário
  clientes           Cliente[]
  materiais          Material[]
  orcamentos         Orcamento[]
  auditLogs          AuditLog[]
  opcoesCustomizadas OpcaoCustomizada[]
}

model Cliente {
  id          Int      @id @default(autoincrement())
  nome        String
  cpfCnpj     String?
  email       String?
  telefone    String
  cidade      String?
  bairro      String?
  rua         String?
  numero      String?
  cep         String?
  observacoes    String?
  telegramChatId String?
  createdAt      DateTime @default(now())
  orcamentos     Orcamento[]

  // Etiqueta de dono (SaaS)
  userId      Int
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Material {
  id                 Int      @id @default(autoincrement())
  nome               String
  categoria          String?
  valor              Float
  unidade            String?
  quantidadeEstoque  Float?
  estoqueMinimo      Float?
  createdAt          DateTime @default(now())

  // Etiqueta de dono (SaaS)
  userId             Int
  user               User     @relation(fields: [userId], references: [id])
  orcamentoMateriais OrcamentoMaterial[]

  @@index([userId])
  @@unique([nome, userId])
}

model Orcamento {
  id              Int      @id @default(autoincrement())
  titulo          String
  clienteId       Int
  cliente         Cliente  @relation(fields: [clienteId], references: [id])
  
  tipoMaoDeObra   String   
  maoDeObraValor  Float
  maoDeObraQtde   Float?   @default(1)
  tipoLucro       String   
  lucroValor      Float
  lucroQtde       Float?   @default(1)
  totalFinal      Float
  status          String   @default("Aguardando")
  
  tipoMovel       String?
  ambiente        String?
  medidas         String?
  prazo           String?
  pagamento       String?
  validade        String?
  observacoes     String?
  
  materiais       OrcamentoMaterial[]
  pagamentos      Pagamento[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Contrato gerado automaticamente ao aprovar
  contratoToken    String?   @unique
  contratoGeradoEm DateTime?
  contratoAceito   Boolean   @default(false)
  contratoAceitoEm DateTime?

  // Etiqueta de dono (SaaS)
  userId          Int
  user            User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@unique([titulo, clienteId, userId])
}

model OrcamentoMaterial {
  id          Int       @id @default(autoincrement())
  orcamentoId Int
  orcamento   Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  nome        String
  valor       Float
  quantidade  Float
  materialId  Int?
  material    Material? @relation(fields: [materialId], references: [id], onDelete: SetNull)
}

model OpcaoCustomizada {
  id        Int      @id @default(autoincrement())
  tipo      String   // "ambiente" | "pagamento" | "material_categoria" | "material_unidade"
  nome      String
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([tipo, nome, userId])
  @@index([userId])
}

model Pagamento {
  id            Int       @id @default(autoincrement())
  orcamentoId   Int
  orcamento     Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  descricao     String
  valor         Float
  dataPagamento DateTime  @default(now())
  createdAt     DateTime  @default(now())

  @@index([orcamentoId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  acao      String
  recurso   String
  recursoId Int?
  detalhe   String?
  criadoEm  DateTime @default(now())

  @@index([userId])
  @@index([criadoEm])
}